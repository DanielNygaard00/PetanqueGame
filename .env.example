# Copy to .env and fill in. .env is gitignored.

# Server
PORT=5001
JWT_SECRET=change-me-to-a-long-random-string

# --- Firestore: choose ONE of the options below ---

# Option A: Real Firebase project via service account file
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json

# Option A (alt): service account as a single-line JSON string
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}

# Option B: Local Firebase emulator (no cloud credentials needed)
# Start with: firebase emulators:start --only firestore
# FIRESTORE_EMULATOR_HOST=localhost:8080
# GCLOUD_PROJECT=petanque-local
